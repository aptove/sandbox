# devops-server container — environment variable reference
# Copy to .env and source before running run.sh, or export inline:
#   HOST_SHARE_PATH=/path/to/project ./run.sh

# HOST_SHARE_PATH
#   Optional. Absolute path on the host machine to bind-mount into the
#   container at /workspace. When set, files are read/written on the host.
#   When unset, /workspace is an empty directory inside the container.
#
# Example:
#   HOST_SHARE_PATH=/Users/yourname/projects/my-app
HOST_SHARE_PATH=

# IMAGE
#   Override the container image to run. Defaults to the latest published image.
#
# Example:
#   IMAGE=ghcr.io/aptove/devops-server:sha-abc1234
IMAGE=ghcr.io/aptove/devops-server:latest
